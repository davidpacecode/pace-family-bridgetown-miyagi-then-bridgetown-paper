<!doctype html>
<html class="wa-cloak" lang="<%= site.locale %>">
  <head>
    <%= render "head", metadata: site.metadata, title: data.title %>
  </head>
  <body class="<%= data.layout %> <%= data.page_class %>">

    <wa-page>

      <header slot="header">
        <%= link_to "/", class: "logo-link" do %>
          <div class="wa-cluster wa-heading-xl" style="font-size: 30px; ">
            <!-- <wa-icon name="family"></wa-icon> -->
            <img src="/images/pace_family_logo_transparent.png" alt="logo" style="height: 100px; width: auto;">
            <h1>The Pace Family</h1>
          </div>
        <% end %>
      </header>

      <nav slot="navigation">
        <%= render Shared::Navbar.new(metadata: site.metadata, resource: resource) %>
      </nav>

      <main>
        <div style="padding: 5ch var(--wa-space-4xl); 
          background: radial-gradient(circle at center, var(--wa-color-brand-fill-quiet), var(--wa-color-brand-fill-normal));
          border-radius: 1rem; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);">

          <%= yield %>
    
        </div>
      </main>

      <footer slot="footer">
        <%= render "footer", metadata: site.metadata %>
      </footer>
    </wa-page>
  </body>
</html>
